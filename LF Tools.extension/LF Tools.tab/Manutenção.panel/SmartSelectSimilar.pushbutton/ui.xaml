<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Select Similar" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="White"
        FontFamily="Segoe UI" ShowInTaskbar="False" ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4fc3f7"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#37474f"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#455a64"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0288d1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#039be5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title/Selection -->
            <RowDefinition Height="*"/>    <!-- Params List -->
            <RowDefinition Height="Auto"/> <!-- Scope -->
            <RowDefinition Height="Auto"/> <!-- Buttons/Preview -->
        </Grid.RowDefinitions>

        <!-- Selection Info -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="🎯 Smart Select Similar" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <Border Background="#2d2d2d" Padding="15" CornerRadius="4" BorderBrush="#3d3d3d" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="ElementNameLabel" Text="Carregando elemento..." FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock x:Name="ElementIdLabel" Text="ID: ---" FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Parameters List Header & Search -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Filtrar Parâmetros:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="SearchBox" Padding="8,5" Background="#2d2d2d" Foreground="White" BorderBrush="#3d3d3d" TextChanged="on_search_changed"/>
            
            <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" Height="300">
                <StackPanel x:Name="ParametersPanel">
                    <!-- Data populated via script -->
                </StackPanel>
            </ScrollViewer>
        </StackPanel>

        <!-- Scope & Presets -->
        <StackPanel Grid.Row="2" Margin="0,10">
            <Rectangle Height="1" Fill="#3d3d3d" Margin="0,5"/>
            <TextBlock Text="Escopo de Busca:" FontWeight="Bold" Margin="0,5"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioActiveView" Content="Vista Ativa" IsChecked="True" Foreground="White" Margin="0,0,20,0"/>
                <RadioButton x:Name="RadioProject" Content="Projeto Inteiro" Foreground="White"/>
            </StackPanel>
            
            <TextBlock Text="Quick Presets:" FontWeight="Bold" Margin="0,10,0,5"/>
            <WrapPanel>
                <Button Content="Família + Tipo" Style="{StaticResource ActionButtonStyle}" Click="on_preset_family_type"/>
                <Button Content="Família + Coment." Style="{StaticResource ActionButtonStyle}" Click="on_preset_family_comments"/>
                <Button Content="Limpar" Style="{StaticResource ActionButtonStyle}" Click="on_clear_all"/>
            </WrapPanel>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="3">
            <Rectangle Height="1" Fill="#3d3d3d" Margin="0,10"/>
            <TextBlock x:Name="PreviewLabel" Text="📊 0 elementos encontrados" Foreground="#4fc3f7" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" IsCancel="True"/>
                <Button Content="Preview" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}" Click="on_preview_click"/>
                <Button Content="Selecionar" Style="{StaticResource PrimaryButtonStyle}" Click="do_select"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
