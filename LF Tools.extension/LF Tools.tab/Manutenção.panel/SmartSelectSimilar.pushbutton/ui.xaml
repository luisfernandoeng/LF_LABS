<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Select Similar  |  LF Tools"
        Height="680" Width="480"
        MinHeight="500" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2"
        Foreground="#333333"
        FontFamily="Segoe UI" FontSize="13"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>

        <SolidColorBrush x:Key="AppBackground"     Color="#F2F2F2"/>
        <SolidColorBrush x:Key="PanelColor"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputColor"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleSurface"     Color="#F8F8F8"/>
        <SolidColorBrush x:Key="BorderColor"       Color="#C8C8C8"/>
        <SolidColorBrush x:Key="DividerColor"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HoverBg"           Color="#F0F0F0"/>
        <SolidColorBrush x:Key="AccentBlue"        Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentBlueHover"   Color="#106EBE"/>
        <SolidColorBrush x:Key="AccentBluePressed" Color="#005A9E"/>
        <SolidColorBrush x:Key="AccentBlueFaint"   Color="#E6F2FA"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#777777"/>
        <SolidColorBrush x:Key="TextMuted"         Color="#999999"/>
        <SolidColorBrush x:Key="TextOnAccent"      Color="#FFFFFF"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background"      Value="{StaticResource DividerColor}"/>
            <Setter Property="Height"          Value="1"/>
            <Setter Property="Margin"          Value="0,8,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="32"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
        </Style>

        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin"     Value="0,12,0,4"/>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBluePressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C4C4C4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- título + badge -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- info elemento -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- busca -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>     <!-- parâmetros -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- escopo + presets -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>  <!-- rodapé -->
        </Grid.RowDefinitions>

        <!-- Título + badge de contagem -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Smart Select Similar"
                       FontSize="20" FontWeight="Light"/>
            <Border Grid.Column="1"
                    Background="{StaticResource AccentBlueFaint}"
                    BorderBrush="{StaticResource AccentBlue}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="10,4" VerticalAlignment="Center">
                <TextBlock x:Name="PreviewLabel"
                           Text="0 elemento(s)"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlue}"/>
            </Border>
        </Grid>

        <!-- Info do elemento de referência -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="14,10">
            <StackPanel>
                <TextBlock x:Name="ElementNameLabel"
                           Text="Carregando..."
                           FontSize="12" FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="ElementIdLabel"
                           Text="ID: —"
                           FontSize="11" Margin="0,3,0,0"
                           Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Border>

        <!-- Campo de busca -->
        <Grid Grid.Row="4">
            <TextBox x:Name="SearchBox"/>
            <TextBlock x:Name="SearchHint"
                       Text="🔍  Buscar parâmetros adicionais..."
                       Foreground="#AAAAAA"
                       FontSize="12"
                       FontStyle="Italic"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </Grid>

        <!-- Lista de parâmetros (dinâmica via Python) -->
        <Border Grid.Row="6" Style="{StaticResource PanelBorder}" Padding="12,6,12,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ParametersPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Escopo + presets -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="ESCOPO DE BUSCA"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton x:Name="RadioActiveView" Content="Vista Ativa"
                             IsChecked="True" Margin="0,0,24,0"
                             Foreground="{StaticResource TextPrimary}" Cursor="Hand"/>
                <RadioButton x:Name="RadioProject" Content="Projeto Inteiro"
                             Foreground="{StaticResource TextPrimary}" Cursor="Hand"/>
            </StackPanel>

            <TextBlock Text="PRESETS RÁPIDOS"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,6"/>
            <WrapPanel>
                <Button x:Name="BtnPresetFamilyType" Content="Família + Tipo"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,6,4"/>
                <Button x:Name="BtnPresetFamilyComments" Content="Família + Comentário"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,6,4"/>
                <Button x:Name="BtnClearAll" Content="Limpar"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,0,4"/>
            </WrapPanel>
        </StackPanel>

        <!-- Rodapé -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="PaintButton" Content="Pintar"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,6,0"/>
                <Button x:Name="ZoomButton" Content="Zoom"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,6,0"/>
                <Button x:Name="BtnPreview" Content="Preview"
                        Style="{StaticResource SecondaryActionButton}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancelar" IsCancel="True"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,8,0"/>
                <Button x:Name="BtnSelect" Content="Selecionar"
                        Style="{StaticResource PrimaryActionButton}"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
