<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Select Similar" 
        Height="760" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0E12" 
        Foreground="#FFF8FAFC"
        FontFamily="Segoe UI" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <SolidColorBrush x:Key="PanelColor" Color="#FF15171C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FF2A2E39"/>
        <SolidColorBrush x:Key="InputColor" Color="#FF0D0E12"/>
        <SolidColorBrush x:Key="AccentTeal" Color="#FF5EEAD4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF94A3B8"/>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentTeal}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder" Width="18" Height="18" BorderThickness="1.5" BorderBrush="{StaticResource BorderColor}" CornerRadius="9" Margin="0,0,10,0" VerticalAlignment="Center" Background="Transparent">
                                <Ellipse x:Name="CheckFill" Width="10" Height="10" Fill="Transparent"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckFill" Property="Fill" Value="{StaticResource AccentTeal}"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RadioBorder" Width="18" Height="18" BorderThickness="1.5" BorderBrush="{StaticResource BorderColor}" CornerRadius="9" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse x:Name="RadioDot" Width="8" Height="8" Fill="{StaticResource AccentTeal}" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioDot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0AFFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentTeal}"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#99F6E4"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title/Selection -->
            <RowDefinition Height="*"/>    <!-- Params List -->
            <RowDefinition Height="Auto"/> <!-- Scope -->
            <RowDefinition Height="Auto"/> <!-- Buttons/Preview -->
        </Grid.RowDefinitions>

        <!-- Selection Info -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="🎯 Smart Select Similar" FontSize="20" FontWeight="Light" Foreground="{StaticResource AccentTeal}" Margin="0,0,0,15"/>
            <Border Background="{StaticResource PanelColor}" Padding="20" CornerRadius="18" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="ElementNameLabel" Text="Carregando elemento..." FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="ElementIdLabel" Text="ID: ---" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Parameters List Header & Search -->
        <Grid Grid.Row="1" Margin="0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Filtrar Parâmetros:" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextSecondary}"/>
            <TextBox Grid.Row="1" x:Name="SearchBox" Padding="12,8" Height="38" 
                    Background="{StaticResource InputColor}" Foreground="White" 
                    BorderBrush="{StaticResource BorderColor}"
                    TextChanged="on_search_changed">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5" CornerRadius="19">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>
            
            <ScrollViewer Grid.Row="2" Margin="0,15,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ParametersPanel">
                    <!-- Data populated via script -->
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Scope & Presets -->
        <StackPanel Grid.Row="2" Margin="0,10">
            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,5"/>
            <TextBlock Text="Escopo de Busca:" FontWeight="SemiBold" Margin="0,8" Foreground="{StaticResource TextSecondary}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                <RadioButton x:Name="RadioActiveView" Content="Vista Ativa" IsChecked="True" Margin="0,0,25,0"/>
                <RadioButton x:Name="RadioProject" Content="Projeto Inteiro" />
            </StackPanel>
            
            <TextBlock Text="Quick Presets:" FontWeight="SemiBold" Margin="0,5,0,8" Foreground="{StaticResource TextSecondary}"/>
            <WrapPanel>
                <Button x:Name="BtnPresetFamilyType" Content="Família + Tipo" Style="{StaticResource ActionButtonStyle}"/>
                <Button x:Name="BtnPresetFamilyComments" Content="Família + Coment." Style="{StaticResource ActionButtonStyle}"/>
                <Button x:Name="BtnClearAll" Content="Limpar" Style="{StaticResource ActionButtonStyle}"/>
            </WrapPanel>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="3">
            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,15"/>
            <TextBlock x:Name="PreviewLabel" Text="📊 0 elementos encontrados" Foreground="{StaticResource AccentTeal}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}" IsCancel="True"/>
                <Button x:Name="PaintButton" Content="🎨 Pintar" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}" Click="on_paint_click"/>
                <Button x:Name="ZoomButton" Content="🔍 Zoom" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}" Click="on_zoom_click"/>
                <Button x:Name="BtnPreview" Content="Preview" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}"/>
                <Button x:Name="BtnSelect" Content="Selecionar" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
