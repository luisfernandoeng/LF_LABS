<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LF Limpeza — Manutenção do Projeto"
        Height="720" Width="960"
        MinHeight="580" MinWidth="820"
        Background="#F2F2F2"
        Foreground="#333333"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- ===== PALETA LIGHT V2 ===== -->
        <SolidColorBrush x:Key="PanelColor"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputColor"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleSurface"       Color="#F8F8F8"/>
        <SolidColorBrush x:Key="BorderColor"         Color="#C8C8C8"/>
        <SolidColorBrush x:Key="DividerColor"        Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HoverBg"             Color="#F0F0F0"/>
        <SolidColorBrush x:Key="AccentBlue"          Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentBlueHover"     Color="#106EBE"/>
        <SolidColorBrush x:Key="AccentBlueFaint"     Color="#E6F2FA"/>
        <SolidColorBrush x:Key="TextPrimary"         Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary"       Color="#777777"/>
        <SolidColorBrush x:Key="TextMuted"           Color="#999999"/>
        <SolidColorBrush x:Key="TextOnAccent"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Danger"              Color="#D13438"/>
        <SolidColorBrush x:Key="DangerHover"         Color="#B22023"/>
        <SolidColorBrush x:Key="WarningBg"           Color="#FFF4CE"/>
        <SolidColorBrush x:Key="WarningBorder"       Color="#FFD966"/>
        <SolidColorBrush x:Key="SubtleDivider"       Color="#00FFFFFF"/>

        <!-- TextBlock base -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"      Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Painel-seção (container de conteúdo) -->
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background"        Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="CornerRadius"      Value="6"/>
            <Setter Property="Padding"           Value="14"/>
        </Style>

        <!-- Cards -->
        <Style x:Key="WarningCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource WarningBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource WarningBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- Separador com key (evita conflito com controles WPF internos) -->
        <Style x:Key="Sep" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource DividerColor}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,10"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"              Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"              Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding"                 Value="8,0"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Height"                  Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton -->
        <Style x:Key="ModernRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,4"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="rb_border" Width="16" Height="16" BorderThickness="1.5"
                                    BorderBrush="{StaticResource BorderColor}" CornerRadius="8"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse x:Name="rb_dot" Width="7" Height="7"
                                         Fill="{StaticResource AccentBlue}" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="rb_dot"    Property="Visibility"  Value="Visible"/>
                                <Setter TargetName="rb_border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="rb_border" Property="Background"  Value="{StaticResource AccentBlueFaint}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="rb_border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,4"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="cb_border" Width="16" Height="16" BorderThickness="1.5"
                                    BorderBrush="{StaticResource BorderColor}" CornerRadius="3"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path x:Name="cb_check" Stretch="Uniform"
                                      Stroke="White" StrokeThickness="2"
                                      Data="M 1,5 L 5,9 L 11,2" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="cb_check"  Property="Visibility"  Value="Visible"/>
                                <Setter TargetName="cb_border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="cb_border" Property="Background"  Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cb_border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão primário (azul) -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="36"/>
            <Setter Property="Padding"     Value="16,0"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn_border" Background="{TemplateBinding Background}"
                                CornerRadius="4" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn_border" Property="Background" Value="{StaticResource AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btn_border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão destrutivo (vermelho) -->
        <Style x:Key="DangerActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Height"     Value="36"/>
            <Setter Property="Padding"    Value="16,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn_border" Background="{TemplateBinding Background}"
                                CornerRadius="4" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn_border" Property="Background" Value="{StaticResource DangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btn_border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (outline) -->
        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Height"           Value="32"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn_border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn_border" Property="Background"   Value="{StaticResource HoverBg}"/>
                                <Setter TargetName="btn_border" Property="BorderBrush"  Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBoxItem sem highlight de seleção (para listas de checkboxes) -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent" Padding="1">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="16,12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="LF Limpeza" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlue}"/>
                <TextBlock Text="Manutenção e otimização do projeto Revit"
                           Style="{StaticResource Hint}" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== FASE 1: CONFIGURAÇÃO ===== -->
        <Grid x:Name="config_grid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition x:Name="col_categories" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ESQUERDA: Operações + Opções -->
            <StackPanel Grid.Column="0">

                <!-- O que limpar -->
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="O que limpar" Style="{StaticResource SectionHeader}"/>

                        <!-- Elementos de modelo -->
                        <TextBlock Text="MODELO" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="op_duplicates_cb"   Content="Elementos Sobrepostos"   IsThreeState="False" IsChecked="True"  Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_conduits_cb"     Content="Eletrodutos Soltos"      IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_orphan_tags_cb"  Content="Tags Órfãs"              IsChecked="False" Style="{StaticResource ModernCheckBox}"/>

                        <!-- Definições e estilos -->
                        <TextBlock Text="DEFINIÇÕES" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,8,0,2"/>
                        <CheckBox x:Name="op_view_templates_cb"  Content="Modelos de Vista"    IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_view_filters_cb"    Content="Filtros de Vista"    IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_text_types_cb"      Content="Tipos de Texto"      IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_line_patterns_cb"   Content="Padrões de Linha"    IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_cad_links_cb"       Content="Links CAD"           IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                        <CheckBox x:Name="op_load_cb"            Content="Tipos de Carga"      IsThreeState="False" IsChecked="False" Style="{StaticResource ModernCheckBox}"/>
                    </StackPanel>
                </Border>

                <!-- Opções para Sobrepostos -->
                <Border x:Name="options_border" Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="Opções — Sobrepostos" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Escopo de análise" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <RadioButton x:Name="scope_view_rb"    GroupName="Scope" Content="Vista ativa"     IsChecked="True" Style="{StaticResource ModernRadio}"/>
                        <RadioButton x:Name="scope_project_rb" GroupName="Scope" Content="Todo o projeto"                   Style="{StaticResource ModernRadio}"/>

                        <Separator Style="{StaticResource Sep}"/>

                        <TextBlock Text="Tolerância (mm)" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Linear:" Style="{StaticResource FieldLabel}" FontSize="11"/>
                            <TextBox   Grid.Column="1" x:Name="tol_curve_tb" Text="1.0"/>
                            <TextBlock Grid.Column="3" Text="Ponto:"  Style="{StaticResource FieldLabel}" FontSize="11"/>
                            <TextBox   Grid.Column="4" x:Name="tol_point_tb" Text="2.0"/>
                        </Grid>
                        <TextBlock Text="Tolerância em mm para comparar posição de elementos."
                                   Style="{StaticResource Hint}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- DIREITA: Categorias para Elementos Sobrepostos -->
            <Border x:Name="categories_panel" Grid.Column="2"
                    Style="{StaticResource PanelBorder}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho + botões -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Categorias — Elementos Sobrepostos"
                                   Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="cat_all_btn"  Content="Todas"   Style="{StaticResource SecondaryActionButton}"
                                    Height="26" FontSize="11" Padding="10,0" Margin="0,0,4,0"/>
                            <Button x:Name="cat_none_btn" Content="Nenhuma" Style="{StaticResource SecondaryActionButton}"
                                    Height="26" FontSize="11" Padding="10,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Lista de categorias -->
                    <ListBox Grid.Row="1" x:Name="categories_lb"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding name}"
                                          IsChecked="{Binding is_checked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ModernCheckBox}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== FASE 2: RESULTADOS ===== -->
        <Grid x:Name="results_grid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Resumo -->
            <Border Grid.Row="0" Style="{StaticResource WarningCard}">
                <TextBlock x:Name="summary_tb" Text="" FontSize="13"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
            </Border>

            <!-- Toolbar -->
            <Grid Grid.Row="1" Margin="0,0,0,6">
                <TextBlock Text="Itens Encontrados" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="res_all_btn"  Content="Marcar Todos"    Style="{StaticResource SecondaryActionButton}" Margin="0,0,4,0"/>
                    <Button x:Name="res_none_btn" Content="Desmarcar Todos" Style="{StaticResource SecondaryActionButton}" Margin="0,0,4,0"/>
                    <Button x:Name="back_btn"     Content="← Configurações" Style="{StaticResource SecondaryActionButton}"/>
                </StackPanel>
            </Grid>

            <!-- DataGrid de resultados -->
            <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="0">
                <DataGrid x:Name="results_dg"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserResizeColumns="True"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="{StaticResource PanelColor}"
                          AlternatingRowBackground="{StaticResource SubtleSurface}"
                          Foreground="{StaticResource TextPrimary}"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          IsReadOnly="False"
                          SelectionMode="Extended">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"       Value="{StaticResource SubtleSurface}"/>
                            <Setter Property="Foreground"       Value="{StaticResource TextSecondary}"/>
                            <Setter Property="Padding"          Value="8,6"/>
                            <Setter Property="FontWeight"       Value="SemiBold"/>
                            <Setter Property="FontSize"         Value="11"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="BorderBrush"      Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <Thumb x:Name="PART_LeftHeaderGripper"  Width="5" HorizontalAlignment="Left"  Cursor="SizeWE" Background="Transparent"/>
                                            <Thumb x:Name="PART_RightHeaderGripper" Width="5" HorizontalAlignment="Right" Cursor="SizeWE" Background="Transparent"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"         Value="6,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="BorderBrush"     Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBg}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="✓" Width="44" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding ItemType}" Width="150" MinWidth="100" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="Foreground"   Value="{StaticResource AccentBlue}"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nome / Categoria" Binding="{Binding Name}" Width="1.4*" MinWidth="160" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" MinWidth="120" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ===== FOOTER: AÇÕES ===== -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="cancel_btn" Grid.Column="0" Content="Fechar"
                    Style="{StaticResource SecondaryActionButton}" Width="90"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="run_btn"     Content="Analisar"
                        Style="{StaticResource PrimaryActionButton}" Width="120" Margin="0,0,8,0"/>
                <Button x:Name="select_btn"  Content="Selecionar no Revit"
                        Style="{StaticResource SecondaryActionButton}" Visibility="Collapsed"
                        Width="170" Margin="0,0,8,0"/>
                <Button x:Name="confirm_btn" Content="Excluir Selecionados"
                        Style="{StaticResource DangerActionButton}" Visibility="Collapsed" Width="190"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
