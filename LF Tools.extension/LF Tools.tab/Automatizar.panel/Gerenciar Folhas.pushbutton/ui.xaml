<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Folhas  |  LF Tools"
        Height="720" Width="1160"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#BBBBBB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Background"      Value="#0078D7"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"              Value="White"/>
            <Setter Property="BorderBrush"             Value="#C8C8C8"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="RowBackground"           Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F8F8"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="SelectionMode"           Value="Extended"/>
            <Setter Property="SelectionUnit"           Value="FullRow"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8E8E8"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="FontSize"                Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#EFEFEF"/>
            <Setter Property="BorderBrush"     Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Foreground"      Value="#444444"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="26"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#C3DDF0"/>
                </MultiTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Foreground"  Value="#222222"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsEditing" Value="True">
                    <Setter Property="BorderBrush"     Value="#0078D7"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding"   Value="12,5"/>
            <Setter Property="FontSize"  Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Background="#0078D7" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Gerenciar Folhas"
                       Foreground="White" FontSize="17" FontWeight="Light"
                       VerticalAlignment="Center" Margin="16,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,14,0">
                <TextBlock Text="Perfil:" Foreground="#BFDFEF" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="ProfileCombo" Width="200" Height="28"
                          FontSize="12" VerticalContentAlignment="Center"/>
                <Button x:Name="ManageProfilesBtn" Content="⚙"
                        Width="28" Height="28" Margin="5,0,0,0"
                        FontSize="14" ToolTip="Gerenciar Perfis"
                        Style="{StaticResource ToolBtn}"/>
            </StackPanel>
        </Grid>

        <!-- ── Toolbar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#FAFAFA"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <WrapPanel Margin="8,5">
                <Button x:Name="SelectAllBtn"    Content="Selecionar Todos"  Style="{StaticResource ToolBtn}"/>
                <Button x:Name="SelectNoneBtn"   Content="Limpar Seleção"    Style="{StaticResource ToolBtn}" Margin="4,0,0,0"/>
                <Separator Width="1" Height="18" Background="#C8C8C8" Margin="8,0"/>
                <Button x:Name="SetFieldBtn"     Content="Setar Campo..."    Style="{StaticResource ToolBtn}"/>
                <Button x:Name="ApplyProfileBtn" Content="Aplicar Perfil"   Style="{StaticResource ToolBtn}" Margin="4,0,0,0"/>
                <Separator Width="1" Height="18" Background="#C8C8C8" Margin="8,0"/>
                <Button x:Name="ExportBtn"       Content="↑ Excel"          Style="{StaticResource ToolBtn}"/>
                <Button x:Name="ImportBtn"       Content="↓ Excel"          Style="{StaticResource ToolBtn}" Margin="4,0,0,0"/>
                <Separator Width="1" Height="18" Background="#C8C8C8" Margin="8,0"/>
                <Button x:Name="RefreshBtn"      Content="↺ Recarregar"     Style="{StaticResource ToolBtn}"/>
            </WrapPanel>
        </Border>

        <!-- ── Tabs ───────────────────────────────────────────────────────── -->
        <TabControl Grid.Row="2" x:Name="MainTabs" Margin="8,6,8,4">

            <!-- Carimbo -->
            <TabItem Header="Carimbo">
                <DataGrid x:Name="CarimboGrid"/>
            </TabItem>

            <!-- Conteúdo (Vistas) -->
            <TabItem Header="Conteúdo (Vistas)">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#FAFAFA"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="8,5">
                            <Button x:Name="SwapViewBtn"
                                    Content="🔄  Trocar Vista..."
                                    Style="{StaticResource ToolBtn}"/>
                            <TextBlock Text="← selecione linhas na tabela e escolha a nova vista"
                                       Foreground="#999999" FontSize="11" FontStyle="Italic"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <DataGrid x:Name="ConteudoGrid"/>
                </DockPanel>
            </TabItem>

            <!-- Revisões -->
            <TabItem Header="Revisões">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Background="#FFF8E1"
                            BorderBrush="#FFE082" BorderThickness="0,0,0,1">
                        <TextBlock Text="ℹ️  Exibição somente leitura. Revisões são atribuídas via Nuvens de Revisão no Revit."
                                   Foreground="#795548" FontSize="11" Padding="10,5"/>
                    </Border>
                    <DataGrid x:Name="RevisoesGrid"/>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- ── Footer ────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#F2F2F2"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="10,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel"
                           Text="—"
                           VerticalAlignment="Center"
                           Foreground="#777777" FontSize="12"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Fechar" IsCancel="True"
                            Style="{StaticResource ToolBtn}"
                            Width="80" Margin="0,0,8,0"/>
                    <Button x:Name="ApplyBtn"
                            Content="▶  Aplicar"
                            Style="{StaticResource PrimaryBtn}"
                            Width="110"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
