<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Crop  |  LF Tools"
        Height="680" Width="560"
        MinHeight="520" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F2F2F2"
        Foreground="#333333"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>

        <!-- ── Paleta ─────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="AppBackground"      Color="#F2F2F2"/>
        <SolidColorBrush x:Key="PanelColor"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputColor"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor"        Color="#C8C8C8"/>
        <SolidColorBrush x:Key="DividerColor"       Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HoverBg"            Color="#F0F0F0"/>
        <SolidColorBrush x:Key="AccentBlue"         Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentBlueHover"    Color="#106EBE"/>
        <SolidColorBrush x:Key="AccentBluePressed"  Color="#005A9E"/>
        <SolidColorBrush x:Key="AccentGreen"        Color="#107C10"/>
        <SolidColorBrush x:Key="AccentGreenHover"   Color="#0E6B0E"/>
        <SolidColorBrush x:Key="AccentGreenPressed" Color="#0C5A0C"/>
        <SolidColorBrush x:Key="TextPrimary"        Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary"      Color="#777777"/>
        <SolidColorBrush x:Key="TextMuted"          Color="#999999"/>
        <SolidColorBrush x:Key="TextOnAccent"       Color="#FFFFFF"/>

        <!-- ── TextBlock ──────────────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- ── Separator ──────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background"      Value="{StaticResource DividerColor}"/>
            <Setter Property="Height"          Value="1"/>
            <Setter Property="Margin"          Value="0,8,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- ── TextBox ────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ───────────────────────────────────────────────── -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,3"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- ── Botão Primário Azul ────────────────────────────────────── -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBluePressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão Primário Verde ───────────────────────────────────── -->
        <Style x:Key="PrimaryGreenButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentGreenHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentGreenPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão Secundário ───────────────────────────────────────── -->
        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C4C4C4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Panel Border ───────────────────────────────────────────── -->
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
        </Style>

        <!-- ── ListBoxItem clean ──────────────────────────────────────── -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"    Value="6,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="24,18,24,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Header -->
            <RowDefinition Height="12"/>     <!-- 1: spacer -->
            <RowDefinition Height="*"/>      <!-- 2: Content -->
            <RowDefinition Height="10"/>     <!-- 3: spacer -->
            <RowDefinition Height="Auto"/>   <!-- 4: Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Smart Crop"
                       FontSize="22" FontWeight="Light"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Ajustar e copiar crop regions de forma inteligente"
                       FontSize="12" Foreground="{StaticResource TextSecondary}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Content ───────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Vista Atual -->
                <Border Style="{StaticResource PanelBorder}" Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Vista Atual" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Nome:" Style="{StaticResource FieldLabel}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="TextBlock_CurrentViewName" Text="—"
                                       Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Crop Box:" Style="{StaticResource FieldLabel}"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       x:Name="TextBlock_CropBoxInfo" Text="—"
                                       Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Modo 1: Ajustar da Seleção -->
                <Border x:Name="Panel_AdjustMode"
                        Style="{StaticResource PanelBorder}" Padding="14,12"
                        Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Ajustar Crop da Seleção" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Ajusta o crop box para cobrir todos os elementos selecionados."
                                   Style="{StaticResource HintText}" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Margem (m):"
                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox x:Name="TextBox_Margin" Grid.Column="1" Text="0.60"/>
                        </Grid>

                        <Button x:Name="Button_AdjustFromSelection"
                                Content="Ajustar Crop Agora"
                                Style="{StaticResource PrimaryGreenButton}"/>
                    </StackPanel>
                </Border>

                <!-- Modo 2: Copiar para Outras Vistas -->
                <Border x:Name="Panel_CopyMode"
                        Style="{StaticResource PanelBorder}" Padding="14,12"
                        Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Copiar para Outras Vistas" Style="{StaticResource SectionHeader}"/>

                        <!-- Seleção rápida -->
                        <TextBlock Text="Seleção rápida" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="Button_FilterSameLevel"
                                    Content="Mesmo Nível"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Grid.Column="2" x:Name="Button_FilterSameDiscipline"
                                    Content="Mesma Disciplina"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Grid.Column="4" x:Name="Button_FilterAll"
                                    Content="Todas"
                                    Style="{StaticResource SecondaryActionButton}"/>
                        </Grid>

                        <!-- Busca -->
                        <TextBlock Text="Filtrar lista:" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TextBox_SearchViews" Margin="0,0,0,8"/>

                        <!-- Lista de Vistas -->
                        <Border Background="{StaticResource InputColor}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1" CornerRadius="4"
                                Height="220" Margin="0,0,0,12">
                            <ListBox x:Name="ListBox_Views"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="4"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      Style="{StaticResource ModernCheckBox}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                                <TextBlock Text="{Binding DisplaySubtitle}"
                                                           Style="{StaticResource HintText}"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Separator/>

                        <!-- Opções -->
                        <TextBlock Text="Opções de cópia" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="CheckBox_EnableCrop"
                                  Content="Ativar Crop nas vistas de destino"
                                  Style="{StaticResource ModernCheckBox}" IsChecked="True"/>
                        <CheckBox x:Name="CheckBox_ShowCropBox"
                                  Content="Mostrar Caixa de Corte (Crop Box)"
                                  Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                        <CheckBox x:Name="CheckBox_CopyAnnotationCrop"
                                  Content="Copiar Annotation Crop"
                                  Style="{StaticResource ModernCheckBox}" IsChecked="False"/>
                        <CheckBox x:Name="CheckBox_ShowAnnotationCrop"
                                  Content="Mostrar Annotation Crop"
                                  Style="{StaticResource ModernCheckBox}" IsChecked="False"
                                  Margin="0,3,0,12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ────────────────────────────────────────────────── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="Button_Cancel" Content="Cancelar"
                        Style="{StaticResource SecondaryActionButton}"
                        Width="90" Margin="0,0,10,0"/>
                <Button x:Name="Button_ApplyCopy"
                        Content="Copiar para 0 Vistas"
                        Style="{StaticResource PrimaryActionButton}"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
