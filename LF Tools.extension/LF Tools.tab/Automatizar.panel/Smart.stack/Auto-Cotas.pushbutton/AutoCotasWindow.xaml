<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto-Cotas - Dimensionamento Automático"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- GroupBox clean -->
        <Style TargetType="GroupBox" x:Key="Gb">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin"   Value="0,6,18,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin"   Value="0,6,18,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin"   Value="0,5,0,0"/>
            <Setter Property="Height"   Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin"       Value="0,5,0,0"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="BorderBrush"  Value="#AAAAAA"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#777"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2,0,4"/>
        </Style>

        <!-- Botão primário (Salvar) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <!-- Botão secundário (Cancelar) -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent" Padding="1">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Auto-Cotas" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Dimensionamento automático por eixo central" Style="{StaticResource Hint}"/>
        </StackPanel>

        <!-- CONFIGURAÇÕES -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F2F2F2">
            <StackPanel Margin="4,0,4,10">
                
                <GroupBox Header="Modo de Seleção" Style="{StaticResource Gb}">
                    <StackPanel>
                        <RadioButton x:Name="rb_ModeSelected" GroupName="Mode" Content="Cotar elementos selecionados" IsChecked="True"/>
                        <RadioButton x:Name="rb_ModeCategory" GroupName="Mode" Content="Cotar por categorias na vista"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="panel_Categories" Header="Categorias de Alvo e Referência" Style="{StaticResource Gb}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="REFERÊNCIA (base)" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="De onde saem as cotas" Style="{StaticResource Hint}"/>
                            <ListBox x:Name="lb_RefCategories" Background="Transparent" BorderThickness="0" MaxHeight="160">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding name}" IsChecked="{Binding is_checked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ALVOS (cotar até)" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="O que será cotado" Style="{StaticResource Hint}"/>
                            <ListBox x:Name="lb_TargetCategories" Background="Transparent" BorderThickness="0" MaxHeight="160">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding name}" IsChecked="{Binding is_checked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Direção" Style="{StaticResource Gb}">
                    <StackPanel>
                        <CheckBox x:Name="chk_DirHorizontal" Content="Horizontal (eixo X)" IsChecked="True"/>
                        <CheckBox x:Name="chk_DirVertical" Content="Vertical (eixo Y)" IsChecked="False"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Opções de Cota" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Text="Offset (mm):" Margin="0,0,0,2"/>
                        <TextBox x:Name="txt_Offset" Text="500"/>
                        <TextBlock Text="Tipo de Cota:" Margin="0,10,0,2"/>
                        <ComboBox x:Name="cb_DimType"/>
                    </StackPanel>
                </GroupBox>

                <Border Background="#FFF3CD" BorderBrush="#FFEEBA" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0">
                    <TextBlock x:Name="lbl_Info" Text="Selecione elementos ou configure as categorias." FontSize="11" Foreground="#856404" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- AÇÕES -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btn_Cancel" Content="Cancelar" Style="{StaticResource BtnCancel}" Margin="0,0,10,0"/>
            <Button x:Name="btn_Generate" Content="  Gerar Cotas  " Style="{StaticResource BtnPrimary}"/>
        </StackPanel>
    </Grid>
</Window>
