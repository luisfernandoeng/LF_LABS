<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerar Folhas - Luís Fernando"
        Height="780" Width="1200"
        Background="#F2F2F2"
        Foreground="#333333"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontFamily="Segoe UI" FontSize="13">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="PanelColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#C8C8C8"/>
        <SolidColorBrush x:Key="InputColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentTeal" Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#107C41"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#777777"/>
        <SolidColorBrush x:Key="Danger" Color="#D13438"/>
        <SolidColorBrush x:Key="Warning" Color="#FFB900"/>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource PanelColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- CAIXAS DE TEXTO (TEXTBOX) -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CAIXA DE SELEÇÃO (COMBOBOX) -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputColor}" 
                                                BorderBrush="{StaticResource BorderColor}" 
                                                BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="25"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextSecondary}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,25,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            
                            <!-- TextBox para edição (IsEditable=True) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0"
                                     Margin="8,0,25,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center" 
                                     Focusable="True"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Name="DropDownBorder" Background="{StaticResource InputColor}" 
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,2,0,0" CornerRadius="4">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                         <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox" x:Key="ModernCheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox" BasedOn="{StaticResource ModernCheckBox}"/>

        <!-- RADIOBUTTON -->
        <Style TargetType="RadioButton" x:Key="ModernRadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton" BasedOn="{StaticResource ModernRadioButton}"/>

        <!-- BOTOES -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="24,8"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333333"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Padding"          Value="16,8"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="0,0,0,3" BorderBrush="Transparent" Margin="0,0,20,0" Padding="0,8,0,8">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox" x:Key="Gb">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="15,10,15,15"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
            <Setter Property="Background"   Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/> 
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <!-- CABEÇALHO -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Gerar Folhas" FontSize="26" FontWeight="Light" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Gerencie e exporte folhas em lote de forma profissional." FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Perfil Ativo:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondary}"/>
                <ComboBox Name="cb_Profiles" Width="200" Margin="0,0,8,0" ToolTip="Selecione um perfil salvo"/>
                <Button Name="btn_AddProfile" Content="＋" Style="{StaticResource SecondaryActionButton}" Width="36" Padding="0" Margin="0,0,4,0" ToolTip="Criar novo perfil" FontSize="16" FontWeight="Bold"/>
                <Button Name="btn_SaveProfile" Content="💾" Style="{StaticResource SecondaryActionButton}" Width="36" Padding="0" Margin="0,0,4,0" ToolTip="Salvar no perfil atual"/>
                <Button Name="btn_DeleteProfile" Content="🗑" Style="{StaticResource SecondaryActionButton}" Width="36" Padding="0" ToolTip="Excluir perfil selecionado"/>
            </StackPanel>
            
            <TextBlock Name="lbl_Count" Visibility="Collapsed" Text="0"/>
        </Grid>

        <!-- CONTEUDO PRINCIPAL -->
        <Grid Grid.Row="1" Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="20"/> 
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- ABA ESQUERDA (Listagem) -->
            <Border Grid.Column="0" Background="{StaticResource PanelColor}" CornerRadius="6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                <TabControl Name="tab_Main" Background="Transparent" BorderThickness="0" Margin="20"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    
                    <!-- TAB SELECAO -->
                    <TabItem Header="Seleção de Folhas">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> 
                                <RowDefinition Height="*"/> 
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Grid.Column="0" Name="chk_SelectAll" Content="Selecionar Tudo" 
                                          VerticalAlignment="Center" ToolTip="Selecionar Todas as Folhas Visíveis"/>

                                <TextBlock Grid.Column="2" Text="🔍" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Grid.Column="3" Name="txt_Search" Height="32" VerticalContentAlignment="Center" Margin="0" Padding="8,0,0,0"/>
                            </Grid>

                            <ListBox Grid.Row="1" Name="lst_Sheets" 
                                     Background="#F8F8F8"
                                     BorderBrush="{StaticResource BorderColor}"
                                     BorderThickness="1"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionMode="Multiple">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="4">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F2F2F2"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#E6F2FA"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="12,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" IsHitTestVisible="False" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Number}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="4" Text="{Binding FileName}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" FontSize="11" Margin="15,0,0,0" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                    
                    <!-- TAB PROGRESSO -->
                    <TabItem Header="Acompanhamento (Progresso)">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Name="lbl_ProgressTitle" Text="Aguardando início..." 
                                           FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Name="lbl_ProgressDetail" Text="" 
                                           FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <Grid Grid.Row="1" Margin="0,0,0,20">
                                <Border Background="#E0E0E0" CornerRadius="6" Height="12"/>
                                <Border Name="progressBar" Background="{StaticResource AccentBlue}" CornerRadius="6" Height="12" 
                                        HorizontalAlignment="Left" Width="0"/>
                                <TextBlock Name="lbl_ProgressPercent" Text="0%" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="9" FontWeight="Bold" Foreground="White"/>
                            </Grid>
                            
                            <Grid Grid.Row="2" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="#E5F3EB" BorderBrush="#C4E1D0" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,5,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="✓" Foreground="#107C41" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Name="lbl_SuccessCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#107C41"/>
                                            <TextBlock Text="Sucesso" FontSize="11" Foreground="#107C41"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="1" Background="#FDE7E9" BorderBrush="#F6C3C6" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="5,0,5,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="✕" Foreground="#D13438" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Name="lbl_ErrorCount" Text="0" FontSize="20" FontWeight="Bold" Foreground="#D13438"/>
                                            <TextBlock Text="Erros" FontSize="11" Foreground="#D13438"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <Border Grid.Column="2" Background="#E6F2FA" BorderBrush="#BEDAFA" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="5,0,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="⏱" Foreground="#0078D7" FontSize="16" VerticalAlignment="Center"/>
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Name="lbl_TimeElapsed" Text="0s" FontSize="20" FontWeight="Bold" Foreground="#0078D7"/>
                                            <TextBlock Name="lbl_TimeLabel" Text="Tempo" FontSize="11" Foreground="#0078D7"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            
                            <Border Grid.Row="3" Background="#F8F8F8" CornerRadius="6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Name="pnl_ExportItems" Margin="10"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="Exportar Formato DWG" Style="{StaticResource Gb}" Margin="0,0,0,15">
                        <StackPanel>
                            <CheckBox Name="chk_ExportDWG" Content="Ativar Exportação DWG" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <StackPanel IsEnabled="{Binding ElementName=chk_ExportDWG, Path=IsChecked}">
                                <TextBlock Text="Setup de Exportação (Revit)" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Name="cb_DWGSetups" Margin="0,0,0,5" IsEditable="True"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Exportar Formato PDF" Style="{StaticResource Gb}">
                        <StackPanel>
                            <CheckBox Name="chk_ExportPDF" Content="Ativar Exportação PDF" FontWeight="SemiBold" Margin="0,0,0,15"/>
                            <StackPanel Name="pnl_PDFSettings" IsEnabled="{Binding ElementName=chk_ExportPDF, Path=IsChecked}">
                                <TextBlock Text="Zoom e Posicionamento" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <RadioButton Name="rb_ZoomFit" Content="Ajustar à Página" GroupName="Z" IsChecked="True"/>
                                <RadioButton Name="rb_Zoom100" Content="Tamanho Real (100%)" GroupName="Z"/>
                                <Separator Background="#E0E0E0" Margin="0,15"/>
                                <TextBlock Text="Opções Avançadas" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <CheckBox Name="chk_HideCrop" Content="Ocultar Região de Recorte" IsChecked="True"/>
                                <CheckBox Name="chk_CombinePDF" Content="Combinar num único PDF"/>
                                <CheckBox Name="chk_DebugMode" Content="Ativar modo Debug (Console)"/>
                                <Separator Background="#E0E0E0" Margin="0,15"/>
                                <TextBlock Text="Nomenclatura" Style="{StaticResource FieldLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Name="txt_NamePattern" Text="{}{Nome da folha}" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="65"/></Grid.ColumnDefinitions>
                                    <ComboBox Name="cb_AvailableParams" Margin="0,0,8,0" IsEditable="True"/>
                                    <Button Name="btn_AddParam" Content="Add" Grid.Column="1" Style="{StaticResource SecondaryActionButton}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Grid.Column="0" Margin="0,0,30,0">
                <TextBlock Text="Pasta de Destino" Style="{StaticResource FieldLabel}" FontWeight="SemiBold"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="45"/></Grid.ColumnDefinitions>
                    <TextBox Name="txt_OutputFolder" IsReadOnly="True" Background="#F8F8F8"/>
                    <Button Name="btn_SelectFolder" Content="..." Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource SecondaryActionButton}"/>
                </Grid>
                <CheckBox Name="chk_OpenFolderAfter" Content="Abrir pasta automaticamente" IsChecked="True" Margin="0,10,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <Button Name="btn_Cancel" Content="Cancelar" Style="{StaticResource SecondaryActionButton}" Width="120" Margin="0,0,15,0"/>
                <Button Name="btn_Start" Content="Iniciar Exportação" Style="{StaticResource PrimaryActionButton}" Width="200"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>