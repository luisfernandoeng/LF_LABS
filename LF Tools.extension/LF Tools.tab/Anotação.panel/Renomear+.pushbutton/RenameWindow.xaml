<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renomear+ - Luís Fernando"
        Height="900" Width="1300"
        Background="#FF111317"
        Foreground="#FFF2F4F8"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelColor" Color="#FF171A1F"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FF313844"/>
        <SolidColorBrush x:Key="InputColor" Color="#FF13161C"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#FF58D68D"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#FFC4A8FA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF2F4F8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFC4CAD4"/>
        <SolidColorBrush x:Key="Danger" Color="#FFF28B82"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,24,0,10"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StandardPanel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputColor}" 
                                                BorderBrush="{StaticResource BorderColor}" 
                                                BorderThickness="1" CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextSecondary}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,25,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            
                            <!-- TextBox para edição (IsEditable=True) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     Margin="8,0,25,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center" 
                                     Focusable="True"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <Border Name="DropDownBorder" Background="{StaticResource InputColor}" 
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,2,0,0">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BorderColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelColor}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2658D68D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="#10243f"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF7ADBA4"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.95" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.95" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0AFFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.95" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.95" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PanelColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="RENOMEAR +" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentGreen}"/>
                    <TextBlock Text="Edição Híbrida (Tipo e Instância)" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
                    <Separator Background="{StaticResource BorderColor}" Margin="0,20,0,5"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="PARÂMETRO ALVO" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="param_cb" Margin="0,0,0,14" IsEditable="True"/>

                        <TextBlock Text="CAIXA DE TEXTO" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                            <Button x:Name="upper_btn" Content="MAIÚSCULAS" Style="{StaticResource SecondaryActionButton}" Width="90" Margin="0,0,10,0"/>
                            <Button x:Name="lower_btn" Content="minúsculas" Style="{StaticResource SecondaryActionButton}" Width="90" Margin="0,0,10,0"/>
                            <Button x:Name="title_btn" Content="Iniciais Maiúsculas" Style="{StaticResource SecondaryActionButton}" Width="120"/>
                        </StackPanel>

                        <TextBlock Text="SUBSTITUIÇÃO (FIND &amp; REPLACE)" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Procurar:"/>
                                <TextBox x:Name="find_simple_tb"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Substituir:"/>
                                <TextBox x:Name="replace_simple_tb"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="COMPOSIÇÃO DE NOME" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Use {Original} para manter o texto atual." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,-10,0,8"/>
                        <TextBox x:Name="name_pattern_tb" Text="{}{Original}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="p_AvailableParams" IsEditable="True"/>
                            <Button x:Name="btn_AddParam" Content="Add" Grid.Column="2" Height="32" Style="{StaticResource SecondaryActionButton}"/>
                        </Grid>
                        
                        <Border Background="#0AFFFFFF" CornerRadius="12" Padding="14" Margin="0,24,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="numbering_cb" Content="Adicionar numeração sequencial" 
                                          FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="Separador:"/>
                                        <TextBox x:Name="num_separator_tb" Text="-" ToolTip="Ex: - ou _ ou ."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="Dígitos:"/>
                                        <TextBox x:Name="num_digits_tb" Text="2" ToolTip="Zeros à esquerda (Ex: 3 = 001)"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <Label Content="Começar em:" ToolTip="Começar a contagem em qual número?"/>
                                        <TextBox x:Name="start_num_tb" Text="1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <Label Content="Adicionar:" ToolTip="Onde adicionar a numeração?"/>
                                        <ComboBox x:Name="num_pos_cb" SelectedIndex="0">
                                            <ComboBoxItem Content="No Fim"/>
                                            <ComboBoxItem Content="No Início"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Ex: (Fim) Texto-01  |  (Início) 01-Texto" FontSize="10" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,0" HorizontalAlignment="Right" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="BUSCA DE PADRÕES INTELIGENTES" Style="{StaticResource SectionHeader}" ToolTip="Use Padrões Inteligentes or Regex Puro para criar regras de substituição."/>
                        <Border Background="#0AFFFFFF" CornerRadius="12" Padding="14" Margin="0,0,0,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="use_regex_cb" Content="Usar Regex Puro (Avançado)" Margin="0,0,0,10"
                                          ToolTip="Marque para usar sintaxe Regex padrão do Python. Se desmarcado, use a sintaxe inteligente simplificada."/>
                                
                                <Label Content="Procurar Padrão:" ToolTip="Sintaxe Inteligente:&#x0a;# = Qualquer número (0-9)&#x0a;@ = Qualquer letra (a-z, A-Z)&#x0a;? = Qualquer caractere&#x0a;() = Capturar um grupo (ex: (#)(@) para capturar número e letra em partes separadas)"/>
                                <TextBox x:Name="old_format_tb" Margin="0,0,0,10" FontFamily="Consolas"
                                         ToolTip="Sintaxe Inteligente:&#x0a;# = Número (ex: ### para 3 números)&#x0a;@ = Letra (ex: @@ para 2 letras)&#x0a;? = Qualquer caractere&#x0a;() = Cria um grupo para resgatar na parte 'Substituir'"/>
                                
                                <Label Content="Substituir por:" ToolTip="Use o texto que deseja, ou digite $1, $2, etc. para reinserir os grupos () capturados na busca."/>
                                <TextBox x:Name="new_format_tb" FontFamily="Consolas"
                                         ToolTip="Você pode digitar texto livre, ou usar $1, $2 para reinserir os grupos que você colocou entre () no campo 'Procurar Padrão'."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button x:Name="update_btn" Content="Atualizar Prévia" Style="{StaticResource SecondaryActionButton}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="cancel_btn" Grid.Column="0" Content="Fechar" Style="{StaticResource SecondaryActionButton}" BorderBrush="Transparent"/>
                        <Button x:Name="apply_btn" Grid.Column="2" Content="APLICAR" Style="{StaticResource PrimaryActionButton}"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#FF111317" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Filtro Rápido:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                    <TextBox x:Name="filter_tb" Width="240" Height="32"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <Button x:Name="select_all_btn" Content="Todos" Width="70" Style="{StaticResource SecondaryActionButton}" Margin="0,0,5,0"/>
                    <Button x:Name="select_none_btn" Content="Nenhum" Width="70" Style="{StaticResource SecondaryActionButton}"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource PanelColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
                <DataGrid x:Name="preview_dg" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Extended" 
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Sel." 
                                                Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                Width="45"
                                                CanUserResize="False">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>

                        <DataGridTextColumn Header="ID" Binding="{Binding elem_id}" Width="60" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        
                        <DataGridTextColumn Header="Elemento / Tipo" Binding="{Binding elem_name}" Width="*" IsReadOnly="True"/>
                        
                        <DataGridTextColumn Header="Valor Atual" Binding="{Binding original}" Width="Auto" MinWidth="150" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="Foreground" Value="#FFD25555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Novo Valor" Binding="{Binding new}" Width="Auto" MinWidth="150" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>