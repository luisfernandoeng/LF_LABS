<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Smart AutoSave - Configurações" 
        Height="580" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D0E12" 
        Foreground="#FFF8FAFC"
        FontFamily="Segoe UI" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <!-- Cores consistentes -->
        <SolidColorBrush x:Key="PanelColor" Color="#FF15171C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FF2A2E39"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF3B82F6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FF94A3B8"/>
        
        <!-- Estilos de CheckBox (igual aos outros plugins) -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder" Width="18" Height="18" BorderThickness="1.5" BorderBrush="{StaticResource BorderColor}" CornerRadius="6" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Path x:Name="CheckMark" Width="10" Height="10" Stretch="Uniform" Fill="#10243f" Data="M 0,4 L 3,7 L 8,0" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo de RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RadioBorder" Width="18" Height="18" BorderThickness="1.5" BorderBrush="{StaticResource BorderColor}" CornerRadius="9" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse x:Name="RadioDot" Width="8" Height="8" Fill="{StaticResource AccentColor}" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioDot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilos de Button (igual aos outros plugins) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="#10243f"/>
            <Setter Property="Padding" Value="25,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A8C7FA"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="⚙️ Smart AutoSave" 
                   FontSize="18" 
                   FontWeight="Light" 
                   Foreground="{StaticResource AccentColor}"
                   Margin="0,0,0,20"/>
        
        <!-- Config Panel -->
        <Border Grid.Row="1" 
                Background="{StaticResource PanelColor}" 
                BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="1"
                CornerRadius="18"
                Padding="20">
            <StackPanel>
                <CheckBox x:Name="EnableAutoSave" 
                          Content="Ativar Smart AutoSave"
                          IsChecked="True"
                          FontWeight="Bold"/>
                          
                <Button x:Name="BtnPauseToggle"
                        Content="⏸️ Pausar Temporariamente"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"
                        Click="on_pause_click"/>
                
                <TextBlock Text="Intervalo:" 
                           Foreground="#888" 
                           Margin="0,15,0,5"/>
                
                <StackPanel Margin="0,5,0,0">
                    <RadioButton x:Name="Radio1min" Content="1 minuto" />
                    <RadioButton x:Name="Radio5min" Content="5 minutos" />
                    <RadioButton x:Name="Radio10min" Content="10 minutos" IsChecked="True"/>
                    <RadioButton x:Name="Radio15min" Content="15 minutos" />
                    <RadioButton x:Name="Radio30min" Content="30 minutos" />
                </StackPanel>
                
                <CheckBox x:Name="ShowToast" 
                          Content="🔔 Mostrar notificação ao salvar"
                          IsChecked="True"
                          Margin="0,15,0,0"/>

                <CheckBox x:Name="BlockUI" 
                          Content="❌ (Opção removida e não mais bloqueia tela)"
                          IsChecked="False"
                          Visibility="Collapsed"/>
                
                <CheckBox x:Name="PlaySound" 
                          Content="🔊 (Opção removida)"
                          IsChecked="False"
                          Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        
        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancelar" 
                    Style="{StaticResource SecondaryButton}" 
                    Margin="0,0,10,0"
                    IsCancel="True"/>
            <Button Content="Salvar" 
                    Style="{StaticResource PrimaryButton}"
                    Click="on_save_config"/>
        </StackPanel>
    </Grid>
</Window>
