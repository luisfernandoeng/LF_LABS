<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Smart AutoSave - Configurações" 
        Height="540" Width="440"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2" 
        Foreground="#333333"
        FontFamily="Segoe UI" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <!-- Paleta Light v2 -->
        <SolidColorBrush x:Key="PanelColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#C8C8C8"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#0078D7"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#777777"/>
        <SolidColorBrush x:Key="TextMuted" Color="#999999"/>

        <!-- Estilo TextBlock Hint -->
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Estilo GroupBox -->
        <Style x:Key="Gb" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Padding" Value="15,10,15,15"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Margin="0,8,0,0"/>
                            <Border Background="#F2F2F2" Margin="10,0,0,0" 
                                    HorizontalAlignment="Left" VerticalAlignment="Top" Padding="4,0">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Primário -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,8"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Secundário -->
        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox e RadioButton padrão -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚙️ Smart AutoSave" 
                       FontSize="22" 
                       FontWeight="Light" 
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Configurações globais do sistema de salvamento automático." 
                       FontSize="12" 
                       Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>
        
        <!-- Config Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Controle Geral" Style="{StaticResource Gb}">
                    <StackPanel>
                        <CheckBox x:Name="EnableAutoSave" 
                                  Content="Ativar Smart AutoSave"
                                  FontSize="14" FontWeight="Bold"/>
                        <TextBlock Style="{StaticResource Hint}" 
                                   Text="Quando ativado, o plugin salvará o projeto periodicamente conforme o intervalo abaixo."/>
                        
                        <Separator Background="#E0E0E0" Margin="0,10"/>
                        
                        <Button x:Name="BtnPauseToggle"
                                Content="⏸️ Pausar Temporariamente"
                                Style="{StaticResource SecondaryActionButton}"
                                Margin="0,5,0,0"
                                HorizontalAlignment="Left"
                                Click="on_pause_click"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Intervalo de Tempo" Style="{StaticResource Gb}">
                    <StackPanel>
                        <RadioButton x:Name="Radio1min" Content="1 minuto (Frequente)" />
                        <RadioButton x:Name="Radio5min" Content="5 minutos" />
                        <RadioButton x:Name="Radio10min" Content="10 minutos (Recomendado)" />
                        <RadioButton x:Name="Radio15min" Content="15 minutos" />
                        <RadioButton x:Name="Radio30min" Content="30 minutos (Longo)" />
                    </StackPanel>
                </GroupBox>
                
                <GroupBox Header="Notificações" Style="{StaticResource Gb}">
                    <StackPanel>
                        <CheckBox x:Name="ShowToast" 
                                  Content="Exibir alerta visual ao salvar"
                                  IsChecked="True"/>
                        <TextBlock Style="{StaticResource Hint}" 
                                   Text="Mostra um pequeno aviso no canto da tela toda vez que um salvamento é concluído."/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancelar" 
                    Style="{StaticResource SecondaryActionButton}" 
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Width="100"/>
            <Button Content="Salvar Configurações" 
                    Style="{StaticResource PrimaryActionButton}"
                    Click="on_save_config"
                    Width="180"/>
        </StackPanel>
    </Grid>
</Window>
