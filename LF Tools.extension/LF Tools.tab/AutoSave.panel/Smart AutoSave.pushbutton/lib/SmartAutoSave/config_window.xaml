<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Smart AutoSave - Configurações" 
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" 
        Foreground="#e0e0e0"
        FontFamily="Segoe UI" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Cores consistentes -->
        <SolidColorBrush x:Key="PanelColor" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3d3d3d"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4fc3f7"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#888888"/>
        
        <!-- Estilos de CheckBox (igual aos outros plugins) -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <!-- Estilos de Button (igual aos outros plugins) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4fc3f7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6fd8ff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="⚙️ Smart AutoSave" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#4fc3f7"
                   Margin="0,0,0,20"/>
        
        <!-- Config Panel -->
        <Border Grid.Row="1" 
                Background="#2d2d2d" 
                BorderBrush="#3d3d3d" 
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
            <StackPanel>
                <CheckBox x:Name="EnableAutoSave" 
                          Content="Ativar Smart AutoSave"
                          IsChecked="True"
                          FontWeight="Bold"/>
                          
                <Button x:Name="BtnPauseToggle"
                        Content="⏸️ Pausar Temporariamente"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"
                        Click="on_pause_click"/>
                
                <TextBlock Text="Intervalo:" 
                           Foreground="#888" 
                           Margin="0,15,0,5"/>
                
                <StackPanel>
                    <RadioButton x:Name="Radio1min" Content="1 minuto" Foreground="#e0e0e0"/>
                    <RadioButton x:Name="Radio5min" Content="5 minutos" Foreground="#e0e0e0"/>
                    <RadioButton x:Name="Radio10min" Content="10 minutos" Foreground="#e0e0e0" IsChecked="True"/>
                    <RadioButton x:Name="Radio15min" Content="15 minutos" Foreground="#e0e0e0"/>
                    <RadioButton x:Name="Radio30min" Content="30 minutos" Foreground="#e0e0e0"/>
                </StackPanel>
                
                <CheckBox x:Name="ShowToast" 
                          Content="🔔 Mostrar notificação ao salvar"
                          IsChecked="True"
                          Margin="0,15,0,0"/>

                <CheckBox x:Name="BlockUI" 
                          Content="❌ (Opção removida e não mais bloqueia tela)"
                          IsChecked="False"
                          Visibility="Collapsed"/>
                
                <CheckBox x:Name="PlaySound" 
                          Content="🔊 (Opção removida)"
                          IsChecked="False"
                          Visibility="Collapsed"/>
            </StackPanel>
        </Border>
        
        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancelar" 
                    Style="{StaticResource SecondaryButton}" 
                    Margin="0,0,10,0"
                    IsCancel="True"/>
            <Button Content="Salvar" 
                    Style="{StaticResource PrimaryButton}"
                    Click="on_save_config"/>
        </StackPanel>
    </Grid>
</Window>
