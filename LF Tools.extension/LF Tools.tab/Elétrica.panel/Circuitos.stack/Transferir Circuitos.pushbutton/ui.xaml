<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transferir Circuitos"
        Width="600" Height="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <Style TargetType="GroupBox">
            <Setter Property="Margin"      Value="0,10,0,0"/>
            <Setter Property="Padding"     Value="10,6,10,10"/>
            <Setter Property="BorderBrush" Value="#C8C8C8"/>
            <Setter Property="Background"  Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin"   Value="0,5,0,0"/>
            <Setter Property="Height"   Value="28"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#0078D7"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="28,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#333"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="28,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="BtnSmall" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#333"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
        </Style>

        <Style x:Key="BtnApply" TargetType="Button">
            <Setter Property="Background"      Value="#107C10"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="6,0,0,0"/>
        </Style>

        <!-- Chip de filtro inativo -->
        <Style x:Key="BtnChip" TargetType="Button">
            <Setter Property="Background"      Value="#E8E8E8"/>
            <Setter Property="Foreground"      Value="#444"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#C0C0C0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,5,3"/>
        </Style>

        <!-- Chip de filtro ativo -->
        <Style x:Key="BtnChipActive" TargetType="Button">
            <Setter Property="Background"      Value="#0078D7"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#005A9E"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,5,3"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: Origem label -->
            <RowDefinition Height="Auto"/> <!-- 1: ComboBox origem -->
            <RowDefinition Height="Auto"/> <!-- 2: Campo de busca -->
            <RowDefinition Height="Auto"/> <!-- 3: Filtros por tipo de carga -->
            <RowDefinition Height="Auto"/> <!-- 4: Toolbar Todos/Nenhum + headers -->
            <RowDefinition Height="Auto"/> <!-- 5: Edição em massa -->
            <RowDefinition Height="*"/>    <!-- 6: Lista de circuitos -->
            <RowDefinition Height="Auto"/> <!-- 7: Destino label -->
            <RowDefinition Height="Auto"/> <!-- 8: ComboBox destino -->
            <RowDefinition Height="Auto"/> <!-- 9: Rodapé -->
        </Grid.RowDefinitions>

        <!-- ═══ Quadro de Origem ═══ -->
        <TextBlock Text="Quadro de origem:" Style="{StaticResource SectionHeader}" Grid.Row="0"/>
        <ComboBox x:Name="cb_SourcePanel" Grid.Row="1" Margin="0,0,0,10"/>

        <!-- ═══ Campo de Busca ═══ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#C8C8C8"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="13"
                           VerticalAlignment="Center" Margin="8,0,4,0" Foreground="#777"/>
                <Grid Grid.Column="1">
                    <TextBox x:Name="tb_Search" BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center" Height="28" FontSize="13"
                             Padding="2,0,0,0"/>
                    <TextBlock x:Name="lbl_SearchPlaceholder"
                               Text="Buscar circuito por nome ou número..."
                               Foreground="#AAA" FontSize="13" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </Grid>
                <Button x:Name="btn_ClearSearch" Grid.Column="2" Content="&#x2715;"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="#999" FontSize="12" Padding="8,0" Margin="0"
                        ToolTip="Limpar busca"/>
            </Grid>
        </Border>

        <!-- ═══ Filtros por Tipo de Carga ═══ -->
        <Border Grid.Row="3" x:Name="border_TypeFilters"
                Background="#F8F8F8" BorderBrush="#E0E0E0"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,6" Padding="6,4">
            <WrapPanel x:Name="wp_TypeFilters" Orientation="Horizontal">
                <!-- Populado dinamicamente via Python -->
            </WrapPanel>
        </Border>

        <!-- ═══ Toolbar ═══ -->
        <Grid Grid.Row="4" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button x:Name="btn_SelectAll"  Content="Todos"  Style="{StaticResource BtnSmall}"/>
                <Button x:Name="btn_SelectNone" Content="Nenhum" Style="{StaticResource BtnSmall}"/>
                <TextBlock x:Name="lbl_CircuitsCount" Text="0 circuitos"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           FontStyle="Italic" Foreground="#999" FontSize="12"/>
            </StackPanel>
            <TextBlock Text="Tens&#xE3;o" Grid.Column="1"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="#0078D7" FontSize="12"/>
            <TextBlock Text="N&#xBA; Polos" Grid.Column="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="#0078D7" FontSize="12"/>
            <TextBlock Text="" Grid.Column="3" Width="28"/>
        </Grid>

        <!-- ═══ Edição em Massa ═══ -->
        <Border Grid.Row="5" Background="#EBF3FB" BorderBrush="#9DC5E8"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,6" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x26A1;" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="Alterar selecionados:" FontSize="12" FontWeight="SemiBold"
                               Foreground="#0078D7" VerticalAlignment="Center"/>
                </StackPanel>
                <ComboBox x:Name="cb_BulkVoltage" Grid.Column="1"
                          Margin="4,0,4,0" Height="26" FontSize="12"
                          ToolTip="Tens&#xE3;o a aplicar nos circuitos selecionados">
                    <ComboBoxItem Content="&#x2014; manter &#x2014;" IsSelected="True"/>
                    <ComboBoxItem Content="127V"/>
                    <ComboBoxItem Content="220V"/>
                    <ComboBoxItem Content="380V"/>
                    <ComboBoxItem Content="440V"/>
                </ComboBox>
                <ComboBox x:Name="cb_BulkPoles" Grid.Column="2"
                          Margin="4,0,4,0" Height="26" FontSize="12"
                          ToolTip="N&#xBA; de polos a aplicar nos circuitos selecionados">
                    <ComboBoxItem Content="&#x2014; manter &#x2014;" IsSelected="True"/>
                    <ComboBoxItem Content="1 polo"/>
                    <ComboBoxItem Content="2 polos"/>
                    <ComboBoxItem Content="3 polos"/>
                </ComboBox>
                <Button x:Name="btn_BulkApply" Grid.Column="3"
                        Content="Aplicar" Style="{StaticResource BtnApply}"
                        ToolTip="Aplica tens&#xE3;o e/ou polos a todos os circuitos marcados"/>
                <TextBlock Grid.Column="4" Width="28"/>
            </Grid>
        </Border>

        <!-- ═══ Lista de Circuitos ═══ -->
        <Border Grid.Row="6" BorderBrush="#C8C8C8" BorderThickness="1"
                Background="White" CornerRadius="4" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <StackPanel x:Name="sp_Circuits" Margin="6,4,6,4"/>
            </ScrollViewer>
        </Border>

        <!-- ═══ Quadro de Destino ═══ -->
        <TextBlock Text="Transferir para qual quadro?" Style="{StaticResource SectionHeader}" Grid.Row="7"/>
        <ComboBox x:Name="cb_DestPanel" Grid.Row="8" Margin="0,0,0,12"/>

        <!-- ═══ Rodapé ═══ -->
        <Grid Grid.Row="9" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock x:Name="lbl_Info" Text="Selecione o quadro de origem."
                           FontStyle="Italic" Foreground="#0078D7" TextWrapping="Wrap"/>
                <CheckBox x:Name="cb_Debug" Content="Ativar Debug Log detalhado"
                          Foreground="#777" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                <Button x:Name="btn_Cancel"   Content="Fechar"
                        Style="{StaticResource BtnCancel}" Margin="0,0,10,0"/>
                <Button x:Name="btn_Transfer" Content="  Transferir  "
                        Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
