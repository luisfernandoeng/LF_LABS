<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuracoes - Conectar Eletrocalha"
        Width="500" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <Style TargetType="GroupBox" x:Key="Gb">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin"   Value="0,6,18,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin"   Value="0,5,0,0"/>
            <Setter Property="Height"   Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin"       Value="0,5,0,0"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="BorderBrush"  Value="#AAAAAA"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#777"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2,0,4"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderBrush="#C8C8C8">
            <TabItem Padding="14,7">
                <TabItem.Header>
                    <TextBlock Text="Familia / Tipo" FontSize="13" FontWeight="SemiBold"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F2F2F2">
                    <StackPanel Margin="4,6,4,10">
                        <GroupBox Header="Familia/Tipo de Eletrocalha" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Escolha o tipo que sera usado nos trechos criados. Use 'Ultima Desenhada' para repetir a eletrocalha mais recente do modelo."/>
                                <ComboBox x:Name="cb_type"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Dimensionamento automatico" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Quando ativado, a largura e altura vem do conector do equipamento. Se nao houver conector valido, usa os valores da aba Dimensoes."/>
                                <CheckBox x:Name="chk_use_connector" Content="Ler dimensoes do conector automaticamente"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Padding="14,7">
                <TabItem.Header>
                    <TextBlock Text="Dimensoes" FontSize="13" FontWeight="SemiBold"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F2F2F2">
                    <StackPanel Margin="4,6,4,10">
                        <GroupBox Header="Largura Padrao (mm)" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Exemplos: 100, 200, 300. Usado quando a dimensao nao puder ser lida do conector."/>
                                <TextBox x:Name="tb_width"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Altura Padrao (mm)" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Exemplos: 50, 100. Usado quando a dimensao nao puder ser lida do conector."/>
                                <TextBox x:Name="tb_height"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Elevacao/Deslocamento (m)" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Deslocamento base em relacao ao nivel atual. Usado em elementos sem conector."/>
                                <TextBox x:Name="tb_offset"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Padding="14,7">
                <TabItem.Header>
                    <TextBlock Text="Geral" FontSize="13" FontWeight="SemiBold"/>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F2F2F2">
                    <StackPanel Margin="4,6,4,10">
                        <GroupBox Header="Desenvolvedor" Style="{StaticResource Gb}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Hint}"
                                    Text="Modo de depuracao avancada."/>
                                <CheckBox x:Name="chk_debug" Content="Ativar modo Debug (Logs detalhados)"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btn_cancel" Content="Cancelar"
                    Style="{StaticResource BtnCancel}" Margin="0,0,10,0"/>
            <Button x:Name="btn_save"   Content="  Salvar  "
                    Style="{StaticResource BtnPrimary}"/>
        </StackPanel>
    </Grid>
</Window>
