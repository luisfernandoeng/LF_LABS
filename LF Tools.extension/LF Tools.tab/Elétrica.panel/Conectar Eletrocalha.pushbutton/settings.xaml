<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações — Conectar Eletrocalha"
        Width="480" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <Style TargetType="GroupBox" x:Key="Gb">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin"   Value="0,6,18,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin"   Value="0,5,0,0"/>
            <Setter Property="Height"   Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin"       Value="0,5,0,0"/>
            <Setter Property="Height"       Value="30"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="BorderBrush"  Value="#AAAAAA"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#777"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2,0,4"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="#F2F2F2">
            <StackPanel Margin="4,6,4,10">

                <GroupBox Header="Tipo de Eletrocalha" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Tipo de eletrocalha que será modelada (ex: Perfurada, Leito, etc.)."/>
                        <ComboBox x:Name="cb_type"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Dimensionamento" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Se ativado, lê as dimensões (largura/altura) direto do conector do equipamento. Caso contrário, usa os valores padrão abaixo."/>
                        <CheckBox x:Name="chk_use_connector" Content="Ler dimensões do conector automaticamente"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Largura (mm)" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Em mm — ex: 100, 200, 300 (Usado se falhar ao ler do conector)."/>
                        <TextBox x:Name="tb_width"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Altura (mm)" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Em mm — ex: 50, 100."/>
                        <TextBox x:Name="tb_height"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Elevação/Deslocamento (m)" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Deslocamento base em metros — ex: 2.80, 3.00. Em relação ao nível atual."/>
                        <TextBox x:Name="tb_offset"/>
                    </StackPanel>
                </GroupBox>
                
                <GroupBox Header="Desenvolvedor" Style="{StaticResource Gb}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Hint}"
                            Text="Modo de depuração avançada (Logging detalhado)."/>
                        <CheckBox x:Name="chk_debug" Content="Ativar modo Debug"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTÕES -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btn_cancel" Content="Cancelar"
                    Style="{StaticResource BtnCancel}" Margin="0,0,10,0"/>
            <Button x:Name="btn_save"   Content="  Salvar  "
                    Style="{StaticResource BtnPrimary}"/>
        </StackPanel>

    </Grid>
</Window>
