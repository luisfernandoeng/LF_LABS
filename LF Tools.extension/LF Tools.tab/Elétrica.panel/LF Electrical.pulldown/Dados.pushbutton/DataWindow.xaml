<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LF Dados"
        Width="310"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="BorderBrush" Value="#C5D8FB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="BtnAction" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F3F4"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#A8C7FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D2E3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnAction}">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#005FA3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#004C85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnAction}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E8EAED"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>
    </Window.Resources>

    <Border Padding="14,12" Background="#F2F2F2">
        <StackPanel>
            <Border Style="{StaticResource StatusPill}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Rack/Quadro: NENHUM"
                               Foreground="#174EA6"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="RACK / PAINEL" Style="{StaticResource SectionLabel}"/>
            <Button Content="Selecionar Rack/Painel de Dados"
                    Style="{StaticResource BtnPrimary}"
                    Click="select_panel_click"/>

            <TextBlock Text="CRIAR REDES" Style="{StaticResource SectionLabel}"/>
            <Button Content="Circuitos individuais (1 por porta)"
                    Style="{StaticResource BtnAction}"
                    Click="individual_click"/>
            <Button Content="Circuito agrupado (todos em uma rede)"
                    Style="{StaticResource BtnAction}"
                    Click="grouped_click"/>

            <Separator Margin="0,10,0,8" Background="#DADCE0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="DebugToggle"
                          Content="Debug"
                          Foreground="#5F6368"
                          FontSize="11"
                          VerticalAlignment="Center"
                          Grid.Column="0"
                          Click="debug_toggle_click"/>
                <Button Grid.Column="1"
                        Content="Atualizar"
                        Style="{StaticResource BtnSecondary}"
                        Height="28"
                        Margin="0,0,6,0"
                        Padding="12,0"
                        Click="refresh_click"/>
                <Button Grid.Column="2"
                        Content="Fechar"
                        Style="{StaticResource BtnSecondary}"
                        Height="28"
                        Padding="12,0"
                        Click="close_click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
