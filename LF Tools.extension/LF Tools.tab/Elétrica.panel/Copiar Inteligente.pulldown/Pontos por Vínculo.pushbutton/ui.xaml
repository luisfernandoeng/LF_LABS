<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Pontos por Vínculo" Height="760" Width="1120"
    MinHeight="560" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="#FF111317" Foreground="#FFF2F4F8"
    FontFamily="Segoe UI"
    UseLayoutRounding="True"
    TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelColor"     Color="#FF171A1F"/>
        <SolidColorBrush x:Key="BorderColor"    Color="#FF313844"/>
        <SolidColorBrush x:Key="InputColor"     Color="#FF13161C"/>
        <SolidColorBrush x:Key="AccentBlue"     Color="#FF007ACC"/>
        <SolidColorBrush x:Key="AccentTeal"     Color="#FF4EC9B0"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="#FFF2F4F8"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="#FFC4CAD4"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#FF6B7280"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"              Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"              Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox escuro com busca -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputColor}"
                                                BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{StaticResource TextSecondary}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0"
                                     Margin="8,0,24,0"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Focusable="True"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <Popup Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220">
                                    <Border Name="DropDownBorder"
                                            Background="{StaticResource InputColor}"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1" Margin="0,2,0,0"
                                            CornerRadius="8">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite"           Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox"  Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,4"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PanelColor}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="5,2"/>
            <Setter Property="Margin"          Value="2"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>      <!-- Seletor de vínculo -->
            <RowDefinition Height="Auto"/>      <!-- Mapeamento de níveis -->
            <RowDefinition Height="Auto"/>      <!-- Cabeçalho colunas -->
            <RowDefinition Height="*"/>         <!-- Lista de famílias -->
            <RowDefinition Height="Auto"/>      <!-- Posição padrão (fallback) -->
            <RowDefinition Height="Auto"/>      <!-- Rodapé -->
        </Grid.RowDefinitions>

        <!-- Seletor de vínculo -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Vínculo:" Margin="0,0,8,0"
                       FontSize="13" FontWeight="SemiBold"/>
            <ComboBox x:Name="cb_Link" Grid.Column="1"
                      IsEditable="True" IsTextSearchEnabled="True"
                      VerticalContentAlignment="Center"/>
            <Button x:Name="btn_Scan" Grid.Column="2" Content="Escanear"
                    Height="28" Width="90" Margin="8,0,0,0"
                    Background="{StaticResource AccentBlue}"
                    BorderBrush="{StaticResource AccentBlue}"
                    FontWeight="Bold"/>
        </Grid>

        <!-- Mapeamento de níveis (gerado em Python após scan) -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8"
                Margin="0,8,0,0" Padding="10,6">
            <StackPanel>
                <TextBlock Text="Mapeamento de Níveis"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,4"/>
                <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="sp_Levels">
                        <TextBlock Text="Escaneie o vínculo para ver os níveis."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="4,2,0,2"/>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Cabeçalho das colunas -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1,1,1,0"
                CornerRadius="8,8,0,0">
            <Grid Margin="4,6,4,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="72"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Família (Vínculo)"
                           Foreground="{StaticResource TextMuted}"
                           FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="2" Text="Qtd"
                           Foreground="{StaticResource TextMuted}"
                           FontWeight="SemiBold" FontSize="11"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Ponto Elétrico"
                           Foreground="{StaticResource TextMuted}"
                           FontWeight="SemiBold" FontSize="11"
                           Margin="4,0,0,0"/>
                <TextBlock Grid.Column="4" Text="Ponto de Dados"
                           Foreground="{StaticResource TextMuted}"
                           FontWeight="SemiBold" FontSize="11"
                           Margin="4,0,0,0"/>
                <TextBlock Grid.Column="5" Text="Pot. (VA)"
                           Foreground="{StaticResource TextMuted}"
                           FontWeight="SemiBold" FontSize="11"
                           Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Lista de famílias (gerada em Python) -->
        <Border Grid.Row="3"
                Background="{StaticResource InputColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="sp_Families" Margin="4,4,4,4"/>
            </ScrollViewer>
        </Border>

        <!-- Posição padrão para famílias sem correspondência (fallback) -->
        <Border Grid.Row="4"
                Background="{StaticResource PanelColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8"
                Margin="0,8,0,0" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Famílias diferentes — Nível:"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="0,0,8,0"/>
                <ComboBox x:Name="cb_DefaultLevel" Grid.Column="1" Height="26"
                          IsEditable="True" IsTextSearchEnabled="True"
                          VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="Altura:"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="8,0,6,0"/>
                <TextBox x:Name="tb_DefaultHeight" Grid.Column="3"
                         Height="26" Text="0,00"
                         TextAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="m"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Rodapé -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Col 0: status + filtro -->
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock x:Name="lbl_Status"
                           Text="Selecione o vínculo e clique em Escanear."
                           FontStyle="Italic"
                           Foreground="{StaticResource AccentTeal}"
                           TextWrapping="Wrap"/>
                <CheckBox x:Name="chk_FilterNonElec"
                          Content="Ocultar famílias não-elétricas (bancadas, mesas, pias...)"
                          Margin="0,6,0,0"
                          Foreground="{StaticResource TextSecondary}"
                          FontSize="11"
                          IsChecked="True"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                <Button x:Name="btn_SelectAll"  Content="Todos"   Width="58"/>
                <Button x:Name="btn_SelectNone" Content="Nenhum"  Width="58"/>
                <Button x:Name="btn_Cancel"     Content="Cancelar" Width="80" Height="28" Margin="8,2,2,2"/>
                <Button x:Name="btn_Place"      Content="Colocar Pontos" Width="120" Height="28"
                        Margin="2" FontWeight="Bold"
                        Background="{StaticResource AccentBlue}"
                        BorderBrush="{StaticResource AccentBlue}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
