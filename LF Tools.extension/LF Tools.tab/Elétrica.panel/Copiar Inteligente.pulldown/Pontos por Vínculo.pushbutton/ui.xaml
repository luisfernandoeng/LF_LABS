<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pontos por Vínculo"
        Height="820" Width="1140"
        MinHeight="600" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F2F2F2"
        Foreground="#333333"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>

        <!-- PALETA -->
        <SolidColorBrush x:Key="AppBackground"     Color="#F2F2F2"/>
        <SolidColorBrush x:Key="PanelColor"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputColor"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleSurface"     Color="#F8F8F8"/>
        <SolidColorBrush x:Key="BorderColor"       Color="#C8C8C8"/>
        <SolidColorBrush x:Key="DividerColor"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HoverBg"           Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SelectionBg"       Color="#E6F2FA"/>
        <SolidColorBrush x:Key="AccentBlue"        Color="#0078D7"/>
        <SolidColorBrush x:Key="AccentBlueHover"   Color="#106EBE"/>
        <SolidColorBrush x:Key="AccentBluePressed" Color="#005A9E"/>
        <SolidColorBrush x:Key="AccentBlueFaint"   Color="#E6F2FA"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#777777"/>
        <SolidColorBrush x:Key="TextMuted"         Color="#999999"/>
        <SolidColorBrush x:Key="TextOnAccent"      Color="#FFFFFF"/>

        <!-- TEXTBLOCK -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"     Value="0,3,0,0"/>
        </Style>

        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="{StaticResource AccentBlue}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- SEPARATOR -->
        <Style TargetType="Separator">
            <Setter Property="Background"      Value="{StaticResource DividerColor}"/>
            <Setter Property="Height"          Value="1"/>
            <Setter Property="Margin"          Value="0,8,0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Height"                   Value="30"/>
            <Setter Property="Background"               Value="{StaticResource InputColor}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsTextSearchEnabled"      Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{StaticResource InputColor}"
                                                BorderBrush="{StaticResource BorderColor}"
                                                BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,24,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" Visibility="Hidden"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}"
                                     Background="Transparent" Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0" Margin="8,0,24,0"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Focusable="True" Visibility="Visible"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240">
                                    <Border Background="{StaticResource InputColor}"
                                            BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1" Margin="0,2,0,0" CornerRadius="4">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX ITEM -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding"    Value="8,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectionBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,4"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- BOTÃO PRIMÁRIO -->
        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBluePressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÃO SECUNDÁRIO -->
        <Style x:Key="SecondaryActionButton" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C4C4C4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PANEL BORDER -->
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
        </Style>

    </Window.Resources>

    <Grid Margin="24,18,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: Título + status -->
            <RowDefinition Height="14"/>     <!-- 1: spacer -->
            <RowDefinition Height="Auto"/>   <!-- 2: Painel de configuração -->
            <RowDefinition Height="10"/>     <!-- 3: spacer -->
            <RowDefinition Height="Auto"/>   <!-- 4: Mapeamento de níveis -->
            <RowDefinition Height="10"/>     <!-- 5: spacer -->
            <RowDefinition Height="*"/>      <!-- 6: Tabela (cabeçalho + lista) -->
            <RowDefinition Height="10"/>     <!-- 7: spacer -->
            <RowDefinition Height="Auto"/>   <!-- 8: Nível padrão fallback -->
            <RowDefinition Height="12"/>     <!-- 9: spacer -->
            <RowDefinition Height="Auto"/>   <!-- 10: Botões de ação -->
        </Grid.RowDefinitions>

        <!-- ── CABEÇALHO ── -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Pontos por Vínculo"
                           FontSize="22" FontWeight="Light"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="lbl_Status"
                           Text="Selecione o vínculo e clique em Escanear."
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ── CONFIGURAÇÃO ── -->
        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- label Vínculo -->
                    <ColumnDefinition Width="*"/>      <!-- combobox -->
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>   <!-- btn Escanear -->
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>   <!-- label Fase -->
                    <ColumnDefinition Width="130"/>    <!-- cb Fase -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>   <!-- chk FilterNonElec -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Vínculo:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cb_Link" Grid.Column="1"
                          IsEditable="True" StaysOpenOnEdit="True"/>
                <Button x:Name="btn_Scan" Grid.Column="3"
                        Content="Escanear" Width="100"
                        Style="{StaticResource PrimaryActionButton}"/>
                        
                <TextBlock Grid.Column="5"
                           Text="Fase alvo:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="cb_Phase" Grid.Column="6"
                          IsEditable="True" StaysOpenOnEdit="True" />
                          
                <CheckBox x:Name="chk_FilterNonElec" Grid.Column="8"
                          Content="Ocultar não-elétricas"
                          Style="{StaticResource ModernCheckBox}"
                          VerticalAlignment="Center" IsChecked="True"/>
            </Grid>
        </Border>

        <!-- ── MAPEAMENTO DE NÍVEIS ── -->
        <Border Grid.Row="4" Style="{StaticResource PanelBorder}" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Mapeamento de Níveis"
                           Style="{StaticResource SectionHeader}"/>
                <ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="sp_Levels">
                        <TextBlock Text="Escaneie o vínculo para ver os níveis."
                                   Style="{StaticResource HintText}" Margin="0"/>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- ── TABELA ── -->
        <Border Grid.Row="6" Style="{StaticResource PanelBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- cabeçalho das colunas -->
                    <RowDefinition Height="*"/>      <!-- lista de famílias -->
                </Grid.RowDefinitions>

                <!-- Cabeçalho das colunas -->
                <Border Grid.Row="0"
                        Background="{StaticResource SubtleSurface}"
                        BorderBrush="{StaticResource DividerColor}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0" Padding="8,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Família (Vínculo)"
                                   Style="{StaticResource ColHeader}"/>
                        <TextBlock Grid.Column="2" Text="Qtd"
                                   Style="{StaticResource ColHeader}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Classif. Carga"
                                   Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="4" Text="Ponto Elétrico"
                                   Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="5" Text="Ponto de Dados"
                                   Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="6" Text="Pot. (VA)"
                                   Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Lista dinâmica de famílias (gerada em Python) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="sp_Families" Margin="4,2,4,4"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── NÍVEL PADRÃO (fallback) ── -->
        <Border Grid.Row="8" Style="{StaticResource PanelBorder}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Nível padrão (famílias sem correspondência):"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cb_DefaultLevel" Grid.Column="1"
                          IsEditable="True" StaysOpenOnEdit="True"/>
                <TextBlock Grid.Column="2"
                           Text="Altura:" FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="12,0,8,0"/>
                <TextBox x:Name="tb_DefaultHeight" Grid.Column="3"
                         Text="0,00" TextAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="m"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── BOTÕES ── -->
        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                <Button x:Name="btn_SelectAll"  Content="Selecionar Todos"
                        Style="{StaticResource SecondaryActionButton}" Margin="0,0,6,0"/>
                <Button x:Name="btn_SelectNone" Content="Nenhum"
                        Style="{StaticResource SecondaryActionButton}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <Button x:Name="btn_Cancel" Content="Cancelar"
                        Style="{StaticResource SecondaryActionButton}"
                        Width="100" Margin="0,0,8,0"/>
                <Button x:Name="btn_Place" Content="Colocar Pontos"
                        Style="{StaticResource PrimaryActionButton}"
                        Width="160"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
