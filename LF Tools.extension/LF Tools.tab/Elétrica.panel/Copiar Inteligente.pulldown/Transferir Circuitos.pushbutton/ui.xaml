<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Transferir Circuitos" Height="500" Width="420"
    WindowStartupLocation="CenterScreen"
    Background="#252526" Foreground="#F1F1F1"
    FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F1F1F1"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="#111111"/> <!-- Blackish for default WPf combo text visibility -->
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Source Title -->
            <RowDefinition Height="Auto"/> <!-- Source Combo -->
            <RowDefinition Height="*"/>    <!-- ListView -->
            <RowDefinition Height="Auto"/> <!-- Target Title -->
            <RowDefinition Height="Auto"/> <!-- Target Combo -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <TextBlock Text="Selecione o quadro de origem:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="0"/>
        
        <ComboBox x:Name="cb_SourcePanel" Grid.Row="1" Height="28" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

        <Border Grid.Row="2" BorderBrush="#3F3F46" BorderThickness="1" Background="#1E1E1E" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="5" Background="#2D2D30">
                    <Button x:Name="btn_SelectAll" Content="Todos" Width="60"/>
                    <Button x:Name="btn_SelectNone" Content="Nenhum" Width="60"/>
                    <TextBlock x:Name="lbl_CircuitsCount" Text="0 circuitos encontrados" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" Foreground="#999"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="sp_Circuits" Margin="10,5,10,10">
                        <!-- Checkboxes go here -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock Text="Transferir os circuitos selecionados para qual quadro?" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5" Grid.Row="3"/>
        <ComboBox x:Name="cb_DestPanel" Grid.Row="4" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

        <Grid Grid.Row="5" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="lbl_Info" Text="Aguardando..." VerticalAlignment="Center" FontStyle="Italic" Foreground="#4EC9B0" TextWrapping="Wrap"/>
            
            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                <Button x:Name="btn_Cancel" Content="Cancelar" Width="85" Height="28" Margin="0,0,10,0"/>
                <Button x:Name="btn_Transfer" Content="Transferir" Width="85" Height="28" FontWeight="Bold" Background="#007ACC" BorderBrush="#007ACC"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
