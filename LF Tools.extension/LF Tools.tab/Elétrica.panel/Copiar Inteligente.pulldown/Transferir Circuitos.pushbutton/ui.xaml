<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transferir Circuitos"
        Width="560" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F2F2F2"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <!-- GroupBox clean -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>
        <Style TargetType="GroupBox" x:Key="Gb">
            <Setter Property="Margin"       Value="0,10,0,0"/>
            <Setter Property="Padding"      Value="10,6,10,10"/>
            <Setter Property="BorderBrush"  Value="#C8C8C8"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin"   Value="0,5,0,0"/>
            <Setter Property="Height"   Value="28"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- CheckBox -->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,4"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- Hint text -->
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#777"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2,0,4"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- Botão primário -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <!-- Botão secundário -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="28,7"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <!-- Botão pequeno (Todos/Nenhum) -->
        <Style x:Key="BtnSmall" TargetType="Button">
            <Setter Property="Background"       Value="#E0E0E0"/>
            <Setter Property="Foreground"       Value="#333"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Padding"          Value="10,3"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Margin"           Value="0,0,6,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Origem -->
            <RowDefinition Height="Auto"/> <!-- ComboBox origem -->
            <RowDefinition Height="Auto"/> <!-- Toolbar Todos/Nenhum -->
            <RowDefinition Height="*"/>    <!-- Lista de circuitos -->
            <RowDefinition Height="Auto"/> <!-- Destino -->
            <RowDefinition Height="Auto"/> <!-- ComboBox destino -->
            <RowDefinition Height="Auto"/> <!-- Rodapé -->
        </Grid.RowDefinitions>

        <!-- ═══ Quadro de Origem ═══ -->
        <TextBlock Text="Quadro de origem:" Style="{StaticResource SectionHeader}" Grid.Row="0"/>
        <ComboBox x:Name="cb_SourcePanel" Grid.Row="1" Margin="0,0,0,10"/>

        <!-- ═══ Toolbar ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="95"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Button x:Name="btn_SelectAll"  Content="Todos"  Style="{StaticResource BtnSmall}"/>
                <Button x:Name="btn_SelectNone" Content="Nenhum" Style="{StaticResource BtnSmall}"/>
                <TextBlock x:Name="lbl_CircuitsCount" Text="0 circuitos"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           FontStyle="Italic" Foreground="#999" FontSize="12"/>
            </StackPanel>
            <TextBlock Text="Nº Polos" Grid.Column="1"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontWeight="SemiBold" Foreground="#0078D7" FontSize="12"/>
        </Grid>

        <!-- ═══ Lista de Circuitos ═══ -->
        <Border Grid.Row="3" BorderBrush="#C8C8C8" BorderThickness="1"
                Background="White" CornerRadius="4" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <StackPanel x:Name="sp_Circuits" Margin="6,4,6,4">
                    <!-- Linhas dinâmicas via Python -->
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ Quadro de Destino ═══ -->
        <TextBlock Text="Transferir para qual quadro?" Style="{StaticResource SectionHeader}" Grid.Row="4"/>
        <ComboBox x:Name="cb_DestPanel" Grid.Row="5" Margin="0,0,0,12"/>

        <!-- ═══ Rodapé ═══ -->
        <Grid Grid.Row="6" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="lbl_Info" Text="Selecione o quadro de origem."
                       VerticalAlignment="Center" FontStyle="Italic"
                       Foreground="#0078D7" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                <Button x:Name="btn_Cancel"   Content="Cancelar"
                        Style="{StaticResource BtnCancel}" Margin="0,0,10,0"/>
                <Button x:Name="btn_Transfer" Content="  Transferir  "
                        Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
